      "link": null,
      "locked": false,
      "text": "On 28th Feb I decided to only advise on \nAI development to people who are paying \nme for my services, and actively automating \nworkflows with AI",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "On 28th Feb I decided to only advise on \nAI development to people who are paying \nme for my services, and actively automating \nworkflows with AI",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
