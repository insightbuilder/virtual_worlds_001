      "updated": 1772239734030,
      "link": null,
      "locked": false,
      "text": "On 27th Feb came across AnythingLLM\nthe app that made Agents, Skills, \ntools, mcp servers and browser accessible\nto AI models.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "On 27th Feb came across AnythingLLM\nthe app that made Agents, Skills, \ntools, mcp servers and browser accessible\nto AI models.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
