      "index": "b1z",
      "roundness": null,
      "seed": 478439632,
      "version": 4478,
      "versionNonce": 1333753653,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772011748109,
      "link": null,
      "locked": false,
