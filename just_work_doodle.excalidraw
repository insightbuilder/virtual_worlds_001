      "isDeleted": false,
      "boundElements": [],
      "updated": 1772011757189,
      "link": null,
      "locked": false,
      "text": "8 - Agents are taking the prompts, where the\nworkflow is started",
      "fontSize": 54.07407407407412,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "8 - Agents are taking the prompts, where the workflow is started",
      "autoResize": false,
      "lineHeight": 1.35
    },
    {
      "id": "140s9BPccXTmGwYnKXLgC",
      "type": "text",
      "x": 6462.239408772571,
      "y": 1557.8331550617565,
      "width": 1140.7863866412472,
      "height": 73.00000000000007,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1p",
